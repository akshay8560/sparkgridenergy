{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.sparkgridenergy.com.au" }],
      "destination": "https://sparkgridenergy.com.au/:path*",
      "permanent": true
    }
  ]
}
